default_platform(:ios)

platform :ios do
  desc "Sync signing certs/profiles and push a build to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "fastlane/AuthKey.p8",
      in_house: false
    )

    match(
      type: "appstore",
      app_identifier: "cm.farmchain.app",
      readonly: true,
      api_key: api_key
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "cm.farmchain.app" => "match AppStore cm.farmchain.app"
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      changelog: "Build MVP v0.5.0 — automated deploy from main"
    )
  end
end

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>cm.farmchain.app</string>
	<key>CFBundleName</key>
	<string>AGROFAMILY</string>
	<key>CFBundleDisplayName</key>
	<string>AGROFAMILY</string>
	<key>CFBundleShortVersionString</key>
	<string>0.5.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>

	<!-- Camera: used for recording accountability videos (farm visits, pickup,
	     delivery, quality checks) and for scanning a security camera's QR code. -->
	<key>NSCameraUsageDescription</key>
	<string>AGROFAMILY uses the camera to record accountability videos (farm visits, pickup, delivery) and to scan your security camera's QR code.</string>

	<!-- Microphone: accountability videos include audio, and voice notes in chat. -->
	<key>NSMicrophoneUsageDescription</key>
	<string>AGROFAMILY uses the microphone to record sound in accountability videos and voice messages in chat.</string>

	<!-- Location: attaching GPS to listings, delivery confirmation, accountability
	     videos, and employee clock-in/out. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>AGROFAMILY uses your location to place your listings, confirm deliveries, and record employee clock-in times.</string>

	<!-- Local network: required to reach user-owned IP cameras/sensors over
	     RTSP/MQTT on the farm's local Wi-Fi network. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>AGROFAMILY connects to your own IP cameras and sensors on the farm's local Wi-Fi network for security monitoring.</string>

	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
